# ============================================================
# SEGURIDAD INTERNA
# ============================================================
INTERNAL_API_KEY=token-api

# ============================================================
# SERVICIO DE CORREO — SendGrid
# ============================================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ============================================================
# SERVICIO DE SMS — Twilio
# ============================================================
TWILIO_ACCOUNT_SID=token
TWILIO_AUTH_TOKEN=token
TWILIO_FROM_NUMBER=number

# ============================================================
# CORREO SMTP — fastapi-mail
# ============================================================
EMAIL_FROM="example@example.com"
EMAIL_BACKEND="smtp"
MAIL_USERNAME="example@example.com.co"
MAIL_PASSWORD="example*"
MAIL_FROM="example@example.com.co"
MAIL_PORT=587
MAIL_SERVER="smtp.example.com"
MAIL_TLS=true
MAIL_SSL=false
MAIL_FROM_NAME="name app"
